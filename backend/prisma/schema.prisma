// ─────────────────────────────────────────────────────────────
// Task Management System — Prisma Schema
// PostgreSQL · Production-ready
// ─────────────────────────────────────────────────────────────

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ───────────────────────────────────────────────────

enum Role {
  ADMIN
  USER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELLED
}

enum ActionType {
  TASK_CREATED
  TASK_UPDATED
  TASK_DELETED
  TASK_STATUS_CHANGED
  TASK_ASSIGNED
  USER_CREATED
  USER_UPDATED
  USER_DELETED
  USER_LOGIN
  USER_LOGOUT
}

// ── Models ──────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(USER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  assignedTasks Task[]     @relation("AssignedTasks")
  createdTasks  Task[]     @relation("CreatedTasks")
  auditLogs     AuditLog[] @relation("AuditActor")

  @@index([email])
  @@index([role])
  @@map("users")
}

model Task {
  id          String     @id @default(uuid())
  title       String     @db.VarChar(255)
  description String?    @db.Text
  status      TaskStatus @default(TODO)

  assignedUserId String?
  assignedUser   User?   @relation("AssignedTasks", fields: [assignedUserId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User   @relation("CreatedTasks", fields: [createdById], references: [id], onDelete: Restrict)

  dueDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([status])
  @@index([assignedUserId])
  @@index([createdById])
  @@index([createdAt])
  @@map("tasks")
}

model AuditLog {
  id           String     @id @default(uuid())
  actorId      String
  actor        User       @relation("AuditActor", fields: [actorId], references: [id], onDelete: Restrict)
  actionType   ActionType
  targetEntity String     @db.VarChar(50) // "Task" | "User"
  targetId     String
  metadata     Json?      // Before/after snapshots, IP, etc.
  ipAddress    String?    @db.VarChar(45)
  createdAt    DateTime   @default(now())

  @@index([actorId])
  @@index([actionType])
  @@index([targetEntity, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}
